# Luxeholic WooCommerce credentials — one shared catalog hosted at
# store.luxeholic.com.au (the only host with WooCommerce actually
# installed). The Australia pair is used as the canonical source by
# scripts/sync-products.ts. All three pairs are also used for the live
# per-product variations fetch (size/color/stock).
WOOCOMMERCE_KEY_INDIA=
WOOCOMMERCE_SECRET_INDIA=
WOOCOMMERCE_KEY_AUSTRALIA=
WOOCOMMERCE_SECRET_AUSTRALIA=
WOOCOMMERCE_KEY_NEWZEALAND=
WOOCOMMERCE_SECRET_NEWZEALAND=

# Supabase products cache — VITE_SUPABASE_URL/VITE_SUPABASE_PUBLISHABLE_KEY
# (already set for the client) are also read server-side for product reads.
# SUPABASE_SERVICE_ROLE_KEY is server-only, required by `npm run sync:products`
# to write into the cache — get it from Supabase Project Settings > API.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only MongoDB config
MONGODB_URI=
MONGODB_DB_NAME=luxeholic

# Firebase (admin login for the blog panel) — fill in from Firebase Console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
# Comma-separated list of emails allowed to use the admin panel
VITE_FIREBASE_ADMIN_EMAILS=
